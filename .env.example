# EdgeIQ License Worker — Environment Variables (Cloudflare Workers)

# Wrangler / Deployment
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token

# License Verification
LICENSE_VERIFY_ENDPOINT=https://license.edgeiqlabs.com/verify

# Stripe Integration
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_LIFETIME_PRODUCT_ID=prod_...
STRIPE_MONTHLY_PRODUCT_ID=prod_...
